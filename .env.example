# Required: Anthropic API key for Claude
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: SEC EDGAR API (free, but requires user agent)
SEC_EDGAR_USER_AGENT=YourName your@email.com

# Optional: NewsAPI.org for real-time news
NEWS_API_KEY=your_newsapi_key_here

# Optional: Alpha Vantage for financial data
ALPHA_VANTAGE_API_KEY=your_alphavantage_key_here

# Optional: Salesforce integration
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_REDIRECT_URI=http://localhost:5173/oauth/callback

# Optional: Slack webhook for sharing
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx
